# Database Configuration (pointing to host PC's XAMPP MySQL database)
DATABASE_URL=mysql+pymysql://root:@host.docker.internal:3306/agent_db

# Ollama Configuration
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5-coder:1.5b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Custom Security API Key (Use this key in VS Code, Continue, or Cline)
AGENT_API_KEY=local_developer_secret_key

# Auto pull the model on startup if it doesn't exist
AUTO_PULL_MODEL=True

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=8919960980:AAEbkkOTd5BREmbSoQFzRqV0ckOhI3kUMFY
